# Pinterest App credentials (from developers.pinterest.com)
PINTEREST_APP_ID=your_app_id
PINTEREST_APP_SECRET=your_app_secret

# OAuth access token (populated by: node cli.js auth login)
PINTEREST_ACCESS_TOKEN=

# Default board ID to post to (can be overridden per-command with --board)
DEFAULT_BOARD_ID=

# Delay in ms between scrape requests (default 2000)
REQUEST_DELAY_MS=2000

# Delay in ms between Pinterest posts in batch mode (default 12000)
PIN_DELAY_MS=12000

# Pinterest sandbox mode (true = use api-sandbox.pinterest.com for testing)
PINTEREST_SANDBOX=false

# Proxy support (optional)
USE_PROXY=false
PROXY_URL=

# OpenAI API key (optional — for AI description polish, uses gpt-4o-mini)
OPENAI_API_KEY=
